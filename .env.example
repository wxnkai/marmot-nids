# =============================================================================
# marmot-nids — Environment Configuration Reference
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Required variables are marked [REQUIRED].
# Variables with defaults are marked [DEFAULT: value].
# =============================================================================


# =============================================================================
# API Server
# =============================================================================

# Host address for the FastAPI server to bind on.
# [DEFAULT: 0.0.0.0]
API_HOST=0.0.0.0

# Port the FastAPI server listens on.
# [DEFAULT: 8000]
API_PORT=8000

# HMAC-SHA256 hash of the API key used for endpoint authentication.
# Generate with: python scripts/generate_api_key.py
# Store only the HASH here — the plaintext key is given to the caller once and never stored.
# [REQUIRED]
API_KEY_HASH=

# Secret used to compute API key HMACs. Must be at least 32 bytes of entropy.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# [REQUIRED]
API_KEY_SECRET=


# =============================================================================
# LLM / Ollama
# =============================================================================

# Base URL for the Ollama API endpoint.
# [DEFAULT: http://localhost:11434]
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name to use for threat analysis.
# Must be pulled in the Ollama instance before use.
# [DEFAULT: gemma3]
LLM_MODEL=gemma3

# Enable or disable LLM-based detection. Set to false to run signature-only.
# [DEFAULT: true]
LLM_ENABLED=true

# Maximum number of flows to collect before sending a batch to the LLM.
# Larger batches improve throughput but increase latency.
# [DEFAULT: 10]
LLM_BATCH_SIZE=10

# Maximum seconds to wait for a batch to fill before processing a partial batch.
# Prevents indefinite delay on low-traffic networks.
# [DEFAULT: 5]
LLM_BATCH_TIMEOUT=5

# Minimum confidence score (0.0–1.0) for an LLM alert to be recorded.
# Alerts below this threshold are silently discarded.
# [DEFAULT: 0.6]
LLM_CONFIDENCE_THRESHOLD=0.6


# =============================================================================
# RAG / ChromaDB
# =============================================================================

# Enable or disable RAG context injection for LLM prompts.
# When disabled, LLM receives only flow statistics without threat intel context.
# [DEFAULT: true]
RAG_ENABLED=true

# Path to the ChromaDB persistence directory.
# [DEFAULT: ./vector_db]
RAG_PERSIST_DIR=./vector_db

# Embedding model name used by ChromaDB for vectorisation.
# Must be available to sentence-transformers locally.
# [DEFAULT: all-MiniLM-L6-v2]
RAG_EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# Number of top-k chunks returned by the RAG retriever per query.
# [DEFAULT: 5]
RAG_TOP_K=5

# Minimum cosine similarity score for a RAG chunk to be included in context.
# Chunks below this threshold are filtered out.
# [DEFAULT: 0.3]
RAG_MIN_SIMILARITY=0.3


# =============================================================================
# Signature Detection
# =============================================================================

# Path to the signatures JSON file.
# [DEFAULT: ./signatures/signatures.json]
SIGNATURE_FILE_PATH=./signatures/signatures.json

# HMAC-SHA256 key used to verify signatures.json integrity on load.
# If this key changes, re-sign the file with: python scripts/sign_signatures.py
# [REQUIRED]
SIGNATURE_HMAC_SECRET=


# =============================================================================
# Packet Capture
# =============================================================================

# Network interface name to capture traffic on.
# Examples: eth0, en0, lo (Linux/macOS), Ethernet (Windows).
# [REQUIRED]
CAPTURE_INTERFACE=eth0

# Maximum number of raw packets held in the capture queue.
# Excess packets are dropped with a warning log entry.
# [DEFAULT: 10000]
CAPTURE_MAX_QUEUE_SIZE=10000

# Number of packets processed per iteration of the flow assembly loop.
# [DEFAULT: 100]
PACKET_PROCESSING_BATCH_SIZE=100


# =============================================================================
# Flow Tracking
# =============================================================================

# Seconds of inactivity after which a flow is considered expired and flushed.
# [DEFAULT: 120]
FLOW_TIMEOUT=120

# Maximum number of concurrent flows held in memory.
# Oldest flows are evicted when this limit is reached.
# [DEFAULT: 50000]
MAX_FLOWS=50000

# Maximum number of packet-length samples stored per flow for statistics.
# Higher values give more accurate stats but use more memory.
# [DEFAULT: 1000]
FLOW_MAX_STAT_SAMPLES=1000


# =============================================================================
# DoS / DDoS Tracking
# =============================================================================

# Width of the sliding window (in seconds) used by DoSTracker counters.
# [DEFAULT: 10]
DOS_WINDOW_SIZE=10

# Number of SYN packets in the window required to trigger a SYN flood alert.
# [DEFAULT: 1000]
DOS_SYN_THRESHOLD=1000

# Number of ICMP packets in the window required to trigger an ICMP flood alert.
# [DEFAULT: 500]
DOS_ICMP_THRESHOLD=500

# Number of RST packets in the window required to trigger an RST flood alert.
# [DEFAULT: 500]
DOS_RST_THRESHOLD=500


# =============================================================================
# Storage (SQLite via SQLModel)
# =============================================================================

# Path to the SQLite database file for alert and flow storage.
# [DEFAULT: ./data/marmot.db]
DB_PATH=./data/marmot.db


# =============================================================================
# Blockchain
# =============================================================================

# Blockchain provider to use for alert audit logging.
# Options:
#   ethereum  — Submit alerts to an Ethereum-compatible node via web3.py
#   none      — NullProvider: alerts are stored in SQLite only (no chain)
# [DEFAULT: none]
BLOCKCHAIN_PROVIDER=none

# RPC endpoint of the Ethereum node (Hardhat local node or remote).
# Only required when BLOCKCHAIN_PROVIDER=ethereum.
# [DEFAULT: http://localhost:8545]
ETHEREUM_RPC_URL=http://localhost:8545

# Private key of the account authorised to call logAlert() on AlertRegistry.
# This account must be the contract owner (deployer).
# WARNING: Never log this value. Never commit this value.
# [REQUIRED when BLOCKCHAIN_PROVIDER=ethereum]
ETHEREUM_PRIVATE_KEY=

# Deployed address of the AlertRegistry smart contract.
# Set automatically by the Hardhat deploy script when using Docker Compose.
# [REQUIRED when BLOCKCHAIN_PROVIDER=ethereum]
CONTRACT_ADDRESS=

# Maximum number of alerts to submit in a single blockchain sync batch.
# [DEFAULT: 20]
BC_BATCH_SIZE=20

# Maximum number of retry attempts for a failed blockchain submission.
# [DEFAULT: 3]
BC_RETRY_MAX=3

# Base backoff in seconds between retry attempts (exponential).
# Actual delay = BC_RETRY_BACKOFF * (2 ** attempt_number)
# [DEFAULT: 2]
BC_RETRY_BACKOFF=2

# Seconds between background blockchain sync runs.
# [DEFAULT: 30]
BC_SYNC_INTERVAL=30


# =============================================================================
# General
# =============================================================================

# Log level for the application.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# [DEFAULT: INFO]
LOG_LEVEL=INFO

# Runtime environment.
# Options: development, production
# Controls debug output, reload behaviour, and log verbosity.
# [DEFAULT: development]
ENVIRONMENT=development
