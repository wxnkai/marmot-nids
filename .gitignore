# =============================================================================
# marmot-nids — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version
__pypackages__/

# ---------------------------------------------------------------------------
# Secrets & environment — NEVER commit real values
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
.envrc

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.py,cover
junit*.xml
cover/

# ---------------------------------------------------------------------------
# Linting / tooling caches
# ---------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.bandit/
.cache
.pdm-python
.pdm-build/
.pixi
.pypirc
.abstra/

# ---------------------------------------------------------------------------
# Node.js / Hardhat (contracts/)
# ---------------------------------------------------------------------------
node_modules/
contracts/artifacts/
contracts/cache/
contracts/typechain-types/
contracts/deployments/local/
contracts/build/

# ---------------------------------------------------------------------------
# ChromaDB / vector store  (regenerated from knowledge/ at runtime)
# ---------------------------------------------------------------------------
vector_db/
chroma_data/
*.chroma
.chroma/

# ---------------------------------------------------------------------------
# LLM model files  (gigabytes — pulled by Ollama at runtime)
# ---------------------------------------------------------------------------
*.gguf
*.ggml
*.bin
*.onnx
models/
ollama_models/

# ---------------------------------------------------------------------------
# Network capture files  (may contain sensitive production traffic)
# ---------------------------------------------------------------------------
*.pcap
*.pcapng
*.pcap.gz
*.cap
captures/

# ---------------------------------------------------------------------------
# Runtime database files  (regenerated from migrations)
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
data/
db.sqlite3
db.sqlite3-journal

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
*.log.*
logs/
pip-log.txt

# ---------------------------------------------------------------------------
# Docs build output
# ---------------------------------------------------------------------------
docs/_build/
/site

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.cursorignore
.cursorindexingignore

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb
profile_default/
ipython_config.py